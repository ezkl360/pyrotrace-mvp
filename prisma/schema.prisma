generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  PYROMETRY_PROVIDER
  INTERNAL_HEAT_TREAT
  CUSTOMER
}

enum UserRole {
  ADMIN
  QUALITY_MANAGER
  PYROMETRY_TECH
  AUDITOR
  CUSTOMER_VIEWER
}

enum TestType {
  SAT
  TUS
  CALIBRATION
  THERMOCOUPLE_USAGE
  MAINTENANCE_CHECK
  ALARM_TEST
  OTHER_TEST
}

enum ScheduleStatus {
  PLANNED
  DUE_SOON
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum RecordStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  VOIDED
}

enum AssetStatus {
  ACTIVE
  DUE_SOON
  OVERDUE
  BLOCKED
  RETIRED
}

enum TemperatureUnit {
  CELSIUS
  FAHRENHEIT
}

enum DocumentCategory {
  SAT_REPORT
  TUS_REPORT
  CALIBRATION_REPORT
  CERTIFICATE
  PHOTO_EVIDENCE
  PROCEDURE
  AUDIT_PACKAGE
  OTHER
}

enum ApplicableStandard {
  AMS2750
  AMS2770
  CQI_9
  CQI_11
  CQI_12
  CUSTOMER_SPECIFIC
  OTHER
}

enum AmsFurnaceClass {
  NOT_APPLICABLE
  CLASS_1
  CLASS_2
  CLASS_3
  CLASS_4
  CLASS_5
  CLASS_6
}

enum AmsInstrumentationType {
  NOT_APPLICABLE
  TYPE_A
  TYPE_B
  TYPE_C
  TYPE_D
  TYPE_E
}

enum CalibrationAssetType {
  PRIMARY_STANDARD
  SECONDARY_STANDARD
  FIELD_TEST_INSTRUMENT
  EQUIPMENT_INSTRUMENTATION
  TEST_THERMOCOUPLE
  REFERENCE_STANDARD
  OTHER
}

enum CalibrationResult {
  PASS
  FAIL
  LIMITED
  AS_FOUND_ONLY
  VOID
}

model Organization {
  id              String           @id @default(cuid())
  name            String           @unique
  type            OrganizationType @default(INTERNAL_HEAT_TREAT)
  legalName       String?
  taxId           String?
  notes           String?
  defaultLanguage String           @default("en")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  users             User[]
  ownedSites        Site[]             @relation("OwnerOrganizationSites")
  customerSites     Site[]             @relation("CustomerOrganizationSites")
  providerLinks     ProviderCustomer[] @relation("ProviderOrg")
  customerLinks     ProviderCustomer[] @relation("CustomerOrg")
  instruments       Instrument[]
  calibrationAssets CalibrationAsset[]
  documents         Document[]
  auditLogs         AuditLog[]
}

model ProviderCustomer {
  id             String   @id @default(cuid())
  providerOrgId String
  customerOrgId String
  serviceScope  String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  providerOrg Organization @relation("ProviderOrg", fields: [providerOrgId], references: [id])
  customerOrg Organization @relation("CustomerOrg", fields: [customerOrgId], references: [id])

  @@unique([providerOrgId, customerOrgId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  role           UserRole @default(CUSTOMER_VIEWER)
  language       String   @default("en")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization   @relation(fields: [organizationId], references: [id])
  assignedSchedules TestSchedule[] @relation("AssignedSchedules")
  approvals         Approval[]
  auditLogs         AuditLog[]
}

model Site {
  id                     String          @id @default(cuid())
  ownerOrganizationId     String
  customerOrganizationId  String?
  name                   String
  code                   String
  address                String?
  city                   String?
  state                  String?
  country                String?
  defaultTemperatureUnit TemperatureUnit @default(CELSIUS)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  ownerOrganization    Organization  @relation("OwnerOrganizationSites", fields: [ownerOrganizationId], references: [id])
  customerOrganization Organization? @relation("CustomerOrganizationSites", fields: [customerOrganizationId], references: [id])
  equipment            Equipment[]
}

model Equipment {
  id                         String                 @id @default(cuid())
  siteId                     String
  equipmentCode              String
  name                       String
  process                    String?
  temperatureUnit            TemperatureUnit        @default(CELSIUS)
  applicableStandard          ApplicableStandard     @default(AMS2750)
  amsFurnaceClass             AmsFurnaceClass        @default(NOT_APPLICABLE)
  amsInstrumentationType      AmsInstrumentationType @default(NOT_APPLICABLE)
  customerSpecificRequirement String?
  furnaceClass                String?
  instrumentationType         String?
  operatingRange              String?
  satFrequencyDays            Int?
  tusFrequencyDays            Int?
  calibrationFrequencyDays    Int?
  status                     AssetStatus            @default(ACTIVE)
  qrCode                     String                 @unique
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  site      Site              @relation(fields: [siteId], references: [id])
  zones     EquipmentZone[]
  schedules TestSchedule[]
  records   PyrometryRecord[]
  documents Document[]

  @@unique([siteId, equipmentCode])
  @@index([applicableStandard, status])
  @@index([temperatureUnit])
}

model EquipmentZone {
  id                  String      @id @default(cuid())
  equipmentId          String
  zoneCode             String
  name                String
  description          String?
  operatingMin         Float?
  operatingMax         Float?
  nominalSetpoint      Float?
  requiresSat          Boolean     @default(true)
  requiresCalibration  Boolean     @default(true)
  status              AssetStatus @default(ACTIVE)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([equipmentId, zoneCode])
  @@index([equipmentId, status])
}

model Instrument {
  id             String      @id @default(cuid())
  organizationId String
  instrumentCode String
  name           String
  type           String
  serialNumber   String?
  calibrationDue DateTime?
  status         AssetStatus @default(ACTIVE)
  qrCode         String      @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization      Organization                 @relation(fields: [organizationId], references: [id])
  correctionFactors InstrumentCorrectionFactor[]
  records           PyrometryRecord[]
  documents         Document[]

  @@unique([organizationId, instrumentCode])
  @@index([organizationId, status])
}

model InstrumentCorrectionFactor {
  id                 String          @id @default(cuid())
  instrumentId       String
  nominalTemperature Float
  correctionFactor   Float
  temperatureUnit    TemperatureUnit
  uncertainty        Float?
  certificateNumber  String?
  notes              String?
  active             Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([instrumentId, temperatureUnit])
  @@unique([instrumentId, nominalTemperature, temperatureUnit])
}

model CalibrationAsset {
  id             String               @id @default(cuid())
  organizationId String
  assetCode      String
  name           String
  type           CalibrationAssetType
  description    String?
  serialNumber   String?
  status         AssetStatus          @default(ACTIVE)
  qrCode         String               @unique
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization             Organization        @relation(fields: [organizationId], references: [id])
  calibrationsAsCalibrated CalibrationRecord[]  @relation("CalibratedAsset")
  calibrationsAsReference  CalibrationRecord[]  @relation("ReferenceAsset")

  @@unique([organizationId, assetCode])
  @@index([organizationId, type, status])
}

model CalibrationRecord {
  id                String            @id @default(cuid())
  calibratedAssetId String
  referenceAssetId  String?
  certificateNumber String?
  calibrationDate   DateTime
  dueDate           DateTime?
  laboratory        String?
  result            CalibrationResult @default(PASS)
  notes             String?
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  calibratedAsset CalibrationAsset  @relation("CalibratedAsset", fields: [calibratedAssetId], references: [id])
  referenceAsset  CalibrationAsset? @relation("ReferenceAsset", fields: [referenceAssetId], references: [id])
  points          CalibrationPoint[]
  documents       Document[]

  @@index([calibratedAssetId, calibrationDate])
  @@index([referenceAssetId])
  @@index([calibratedAssetId, active])
}

model CalibrationPoint {
  id                 String          @id @default(cuid())
  calibrationRecordId String
  nominalTemperature Float
  indicatedReading   Float?
  referenceReading   Float?
  correctionFactor   Float
  temperatureUnit    TemperatureUnit
  uncertainty        Float?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  calibrationRecord CalibrationRecord @relation(fields: [calibrationRecordId], references: [id])

  @@index([calibrationRecordId, temperatureUnit])
  @@unique([calibrationRecordId, nominalTemperature, temperatureUnit])
}

model ReferenceStandard {
  id             String      @id @default(cuid())
  code           String      @unique
  description    String
  uncertainty    String?
  calibrationDue DateTime?
  status         AssetStatus @default(ACTIVE)
  qrCode         String      @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  records   PyrometryRecord[]
  documents Document[]
}

model Thermocouple {
  id               String      @id @default(cuid())
  code             String      @unique
  type             String
  lot              String?
  maxUses          Int?
  currentUses      Int         @default(0)
  maxExposureHours Float?
  exposureHours    Float       @default(0)
  maxTemperature   Float?
  status           AssetStatus @default(ACTIVE)
  qrCode           String      @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  records   PyrometryRecord[]
  documents Document[]
}

model ComplianceRule {
  id                     String                 @id @default(cuid())
  name                   String
  applicableStandard     ApplicableStandard
  testType               TestType
  temperatureUnit        TemperatureUnit
  amsFurnaceClass         AmsFurnaceClass        @default(NOT_APPLICABLE)
  amsInstrumentationType  AmsInstrumentationType @default(NOT_APPLICABLE)
  toleranceLimit         Float
  toleranceLabel         String?
  active                 Boolean                @default(true)
  notes                  String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  records PyrometryRecord[]

  @@index([applicableStandard, testType, temperatureUnit])
  @@index([amsFurnaceClass, amsInstrumentationType])
}

model TestSchedule {
  id               String         @id @default(cuid())
  equipmentId      String
  type             TestType
  title            String
  plannedStart     DateTime
  plannedEnd       DateTime?
  dueDate          DateTime
  assignedToUserId String?
  status           ScheduleStatus @default(PLANNED)
  recurrenceRule   String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  equipment  Equipment         @relation(fields: [equipmentId], references: [id])
  assignedTo User?             @relation("AssignedSchedules", fields: [assignedToUserId], references: [id])
  records    PyrometryRecord[]

  @@index([type, dueDate, status])
}

model PyrometryRecord {
  id                  String       @id @default(cuid())
  scheduleId          String?
  equipmentId         String
  instrumentId        String?
  thermocoupleId      String?
  referenceStandardId String?
  complianceRuleId    String?
  type                TestType
  status              RecordStatus @default(DRAFT)
  performedAt         DateTime?
  result              String?
  tolerance           Float?
  maxError            Float?
  maxDeviation        Float?
  technicianNotes     String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  schedule          TestSchedule?      @relation(fields: [scheduleId], references: [id])
  equipment         Equipment          @relation(fields: [equipmentId], references: [id])
  instrument        Instrument?        @relation(fields: [instrumentId], references: [id])
  thermocouple      Thermocouple?      @relation(fields: [thermocoupleId], references: [id])
  referenceStandard ReferenceStandard? @relation(fields: [referenceStandardId], references: [id])
  complianceRule    ComplianceRule?    @relation(fields: [complianceRuleId], references: [id])
  documents         Document[]
  approvals         Approval[]
  riskAssessments   RiskAssessment[]
  satRecord         SatRecord?
}

model SatRecord {
  id                        String   @id @default(cuid())
  pyrometryRecordId          String   @unique
  setpoint                  Float
  systemReading             Float
  referenceReading          Float
  correctionFactor          Float    @default(0)
  correctedReferenceReading Float
  error                     Float
  absoluteError             Float
  pass                      Boolean
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  pyrometryRecord PyrometryRecord @relation(fields: [pyrometryRecordId], references: [id])
}

model Document {
  id                  String           @id @default(cuid())
  organizationId      String
  equipmentId         String?
  recordId            String?
  instrumentId        String?
  thermocoupleId      String?
  referenceStandardId String?
  calibrationRecordId String?
  category            DocumentCategory
  title               String
  fileName            String
  storageBucket       String           @default("pyrotrace-reports")
  storagePath         String
  mimeType            String?
  sizeBytes           Int?
  version             Int              @default(1)
  checksum            String?
  uploadedBy          String?
  language            String           @default("en")
  createdAt           DateTime         @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id])
  equipment         Equipment?         @relation(fields: [equipmentId], references: [id])
  record            PyrometryRecord?   @relation(fields: [recordId], references: [id])
  instrument        Instrument?        @relation(fields: [instrumentId], references: [id])
  thermocouple      Thermocouple?      @relation(fields: [thermocoupleId], references: [id])
  referenceStandard ReferenceStandard? @relation(fields: [referenceStandardId], references: [id])
  calibrationRecord CalibrationRecord? @relation(fields: [calibrationRecordId], references: [id])

  @@index([organizationId, category, createdAt])
}

model Approval {
  id        String       @id @default(cuid())
  recordId  String
  userId    String
  status    RecordStatus
  comment   String?
  createdAt DateTime     @default(now())

  record PyrometryRecord @relation(fields: [recordId], references: [id])
  user   User            @relation(fields: [userId], references: [id])
}

model RiskAssessment {
  id             String   @id @default(cuid())
  recordId       String
  level          String
  score          Float
  explanation    String
  recommendation String?
  createdAt      DateTime @default(now())

  record PyrometryRecord @relation(fields: [recordId], references: [id])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  entityType     String
  entityId       String
  action         String
  reason         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([entityType, entityId, createdAt])
}
