services:
  postgres:
    image: postgres:16
    container_name: pyrotrace-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: pyrotrace
    ports:
      - "5433:5432"
    volumes:
      - pyrotrace_pg:/var/lib/postgresql/data
volumes:
  pyrotrace_pg:
